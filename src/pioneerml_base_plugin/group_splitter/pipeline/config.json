{
  "training": {
    "hpo": {
      "architecture": {
        "type": "group_splitter",
        "config": {
          "node_dim": 4,
          "edge_dim": 4,
          "graph_dim": 3,
          "hidden": 128,
          "heads": 4,
          "layers": 3,
          "dropout": 0.1,
          "num_classes": 3
        }
      },
      "module": {
        "type": "graph_lightning",
        "config": {
          "loss": {
            "type": "bce_with_logits",
            "config": {}
          },
          "lr": 0.001,
          "weight_decay": 0.0001,
          "scheduler_step_size": 2,
          "scheduler_gamma": 0.5
        }
      },
      "trainer": {
        "type": "lightning_module",
        "config": {
          "trainer_kwargs": {
            "enable_progress_bar": true,
            "max_epochs": 10,
            "gradient_clip_val": 2.0
          },
          "early_stopping": {
            "enabled": true,
            "type": "relative",
            "config": {
              "monitor": "val_loss",
              "mode": "min",
              "patience": 5,
              "min_delta": 0.05,
              "strict": true,
              "check_finite": true,
              "verbose": false
            }
          }
        }
